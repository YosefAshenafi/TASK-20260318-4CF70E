# ──────────────────────────────────────────────────────────────
# PharmaOps – required environment variables
# Copy to .env and adjust for your deployment.
# ──────────────────────────────────────────────────────────────

# ── HTTP server ───────────────────────────────────────────────
HTTP_ADDR=:8080

# ── MySQL connection ──────────────────────────────────────────
MYSQL_DSN=pharmaops:pharmaops@tcp(db:3306)/pharmaops?parseTime=true&loc=UTC&charset=utf8mb4

# ── MySQL container (used by docker-compose) ──────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=pharmaops
MYSQL_USER=pharmaops
MYSQL_PASSWORD=pharmaops

# ── Application mode ──────────────────────────────────────────
# "development" enables Gin debug mode; "production" sets release mode.
APP_ENV=development

# ── PII encryption (AES-256) ─────────────────────────────────
# 64 hex characters (32 bytes). REQUIRED for candidate PII at rest.
# Generate with: openssl rand -hex 32
PII_AES_KEY_HEX=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ── File storage ──────────────────────────────────────────────
# Absolute path for uploaded files, chunks, and merged objects.
FILE_STORAGE_ROOT=/var/lib/pharmaops/files

# ── Health check (optional) ───────────────────────────────────
# When set, GET /api/v1/health requires X-Internal-Health-Token header.
HEALTH_CHECK_TOKEN=

# ── Session ───────────────────────────────────────────────────
# Default session TTL is 8 hours (compiled default; no env override yet).
